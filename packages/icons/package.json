{
  "name": "@repo/icons",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "node ./scripts/generate-icons.mjs",
    "generate:yaml": "node ./scripts/generate-icons-yaml.mjs",
    "build": "tsdown src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3"
  }
}
